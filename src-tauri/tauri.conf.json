{
  "productName": "Gaming PC Optimizer",
  "version": "1.1.0",
  "identifier": "com.gaming-optimizer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gaming PC Optimizer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyN0JCMjQ3RDc4QUYxM0MKUldRODhZclhSN0o3c29nZFB4UGtNQldPUmszaGZWY3AxS1VwNS9VNGRZRVFHZzdvNE8xbmYvZUcK",
      "endpoints": [
        "https://raw.githubusercontent.com/rsn1224/gaming-pc-optimizer/main/latest.json"
      ]
    }
  }
}
